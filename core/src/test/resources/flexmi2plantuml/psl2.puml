@startuml
allowmixing
hide stereotypes
skinparam roundCorner 3
skinparam defaultFontName system-ui
skinparam ArrowColor #7A7A7A




rectangle "ACME" as n0 <<n0type>>  {
    node "<<Task>>\nAnalysis" as n1 <<n1type>> 
    node "<<Task>>\nDesign" as n2 <<n2type>> 
    node "<<Task>>\nImplementation" as n3 <<n3type>> 
    cloud "Alice" as n4 <<n4type>> 
    cloud "Manager: Bob" as n5 <<n5type>> 
} 


<style>

._Pattern {
    BackgroundColor gold
    LineColor %darken("gold",60)
}

._Critique {
    BackgroundColor khaki
    LineColor %darken("khaki",60)    
}

._Constraint {
    BackgroundColor mistyrose
    LineColor %darken("mistyrose",60)
}

._Success {
    BackgroundColor TECHNOLOGY
    LineColor %darken("TECHNOLOGY",60)
}

.n0type {
    LineColor #606666
    BackgroundColor azure
    
}
.n1type {
    LineColor #626258
    BackgroundColor beige
    
    fontcolor green
}
.n2type {
    LineColor #626258
    BackgroundColor beige
    
    fontcolor green
}
.n3type {
    LineColor #626258
    BackgroundColor beige
    
    fontcolor green
}
.n4type {
    LineColor #606666
    BackgroundColor azure
    
    fontcolor magenta
    fontsize 20
}
.n5type {
    LineColor #003300
    BackgroundColor green
    
    fontcolor white
}
</style>

n4 -[thickness=10]down-> n1
n5 -[thickness=10]down-> n2
n5 -[thickness=5]down-> n3: 50%
n4 -[thickness=5]down-> n3: 50%

n2 -[#red,dashed,thickness=2]right-> n4: leads



@enduml

