@namespace(uri="stm", prefix="")
package stm;

class StateMachine {
    attr String name;
	val State[*] states;
	val Transition[*] transitions;
}

@node(label="name")
class State {
    attr String name;
    ref Transition[*]#from outgoing;
    ref Transition[*]#to incoming;
}

@edge(source="from", target="to", direction="down")
class Transition {
    ref State#outgoing from;
    ref State#incoming to;
}