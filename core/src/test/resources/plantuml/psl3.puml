                    rectangle "Bob" as n5_1 <<n5type>> 
                } 
                rectangle "Implementation" as n3_1 <<n3type>> 
            } 
            rectangle "Alice" as n4_2 <<n4type>> 
        } 
    } 
    rectangle "Bob" as n5_2 <<n5type>> 
} 


