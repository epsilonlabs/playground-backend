@startuml
allowmixing
hide stereotypes
skinparam roundCorner 3
skinparam defaultFontName system-ui
skinparam ArrowColor #7A7A7A




rectangle "ACME" as n0 <<n0type>>  {
    rectangle "Alice" as n4 <<n4type>>  {
        rectangle "Analysis" as n1 <<n1type>>  {
            rectangle "Alice" as n4_1 <<n4type>> 
        } 
        rectangle "Implementation" as n3 <<n3type>>  {
            rectangle "Bob" as n5 <<n5type>>  {
