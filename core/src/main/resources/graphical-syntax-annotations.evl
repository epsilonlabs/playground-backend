pre {
    var edgeDecorations = Set{"none", "rhomb", "arrow", "arrow.filled", "arrow.empty", "diamond", "diamond.empty"};
    var directions = Set{"up", "down", "left", "right"};
}

context EAnnotation {
    
    guard: self.source = "node" and self.eContainer().isTypeOf(EClass)
    
    constraint Contents {
        guard: self.getDetail("contents").isDefined()
        check {
            var unknownFeatures = self.getDetail("contents").split(",").collect(n|n.trim()).
            reject(name|self.eContainer().eAllStructuralFeatures.exists(r:EReference|r.name = name));
            return unknownFeatures.isEmpty();
        }
        message: "Content feature" + (unknownFeatures.size() > 1 ? "s" : "") + " '" + unknownFeatures.concat(", ") + "' not found in class " + self.eContainer().name
    }
}

context EAnnotation {
    
    guard: self.source = "edge" or self.source = "node" and self.eContainer().isTypeOf(EClass)
    
    constraint Label {
        guard: self.getDetail("label").isDefined()
        check: self.eContainer().eAllStructuralFeatures.exists(a:EAttribute|a.name = self.getDetail("label"))
        message: "Label feature '" + self.getDetail("label") + "' not found in class " + self.eContainer().name
    }
    
    constraint Created {
        guard: self.getDetail("created").isDefined()
        check: self.getDetail("created").isBoolean()
        message: "The 'created' flag of class " + self.eContainer().name + " must be set to true or false"
    }
    
}

context EAnnotation {
    
    guard: self.source = "edge" and self.eContainer().isTypeOf(EClass)
    
    constraint SourceDefined {
        check: self.hasDetail("source")
        message: "Edge class " + self.eContainer().name + " must specify a source reference"
    }
    
    constraint Source {
        guard: self.getDetail("source").isDefined()
        check: self.eContainer().eAllStructuralFeatures.exists(r:EReference|r.name = self.getDetail("source") and not r.isMany())
        message: "Edge source '" + self.getDetail("source") + "' is not a single-valued reference of class " + self.eContainer().name
    }
    
    constraint TargetDefined {
        check: self.hasDetail("target")
        message: "Edge class " + self.eContainer().name + " must specify a target reference"
    }
    
    constraint Target {
        guard: self.getDetail("target").isDefined()
        check: self.eContainer().eAllStructuralFeatures.exists(r:EReference|r.name = self.getDetail("target") and not r.isMany())
        message: "Edge target '" + self.getDetail("target") + "' is not a single-valued reference of class " + self.eContainer().name
    }
    
}

context EAnnotation {
    
    guard: self.source = "edge" and (self.eContainer.isTypeOf(EClass) or self.eContainer.isTypeOf(EReference))

    constraint Direction {
        guard: self.getDetail("direction").isDefined()
        check: self.isValidDetail("direction", directions)
        message: "Invalid value '" + self.getDetail("direction") + "' for the direction of edge " + self.getClassOrReferenceName()
    }
    
    constraint SourceDecoration {
        guard: self.getDetail("sourceDecoration").isDefined()
        check: self.isValidDetail("sourceDecoration", edgeDecorations)
        message: "Invalid value '" + self.getDetail("sourceDecoration") + "' for the source decoration of edge " + self.getClassOrReferenceName()
    }
    
    constraint TargetDecoration {
        guard: self.getDetail("targetDecoration").isDefined()
        check: self.isValidDetail("targetDecoration", edgeDecorations)
        message: "Invalid value '" + self.getDetail("targetDecoration") + "' for the target decoration of edge " + self.getClassOrReferenceName()
    }
    
    constraint Visible {
        guard: self.getDetail("visible").isDefined()
        check: self.getDetail("visible").isBoolean()
        message: "The 'visible' flag of class " + self.eContainer().name + " must be set to true or false"
    }
}

operation EAnnotation hasDetail(detail : String) : Boolean {
    var value = self.details.get(detail);
    if (value.isDefined()) return true;
    else return false;
}

operation EAnnotation isValidDetail(detail : String, validOptions : Set) : Boolean {
    return validOptions.includes(self.getDetail(detail));
}

operation EAnnotation getDetail(detail : String) : String {
    var value = self.details.get(detail);
    if (value.isDefined() and not value.startsWith("eol:")) return value;
    else return null;
}

operation EAnnotation getClassOrReferenceName() : String {
    return self.eContainer().isTypeOf(EClass) ? self.eContainer().name : (self.eContainer().eContainer().name + '.' + self.eContainer().name);
}

operation String isBoolean() {
    return self == "true" or self == "false";
}